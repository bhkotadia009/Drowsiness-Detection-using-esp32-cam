#include "esp_camera.h"
#include "esp_http_server.h"
#include <WiFi.h>

// ── CONFIG ────────────────────────────────────────────────────────────────────
#define BUZZER_PIN  12          // GPIO connected to buzzer
const char* ssid     = "YOUR_WIFI_NAME";
const char* password = "YOUR_WIFI_PASSWORD";
// ─────────────────────────────────────────────────────────────────────────────

// ── CAMERA PIN MAP (AI-Thinker ESP32-CAM) ────────────────────────────────────
#define PWDN_GPIO_NUM     32
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM      0
#define SIOD_GPIO_NUM     26
#define SIOC_GPIO_NUM     27
#define Y9_GPIO_NUM       35
#define Y8_GPIO_NUM       34
#define Y7_GPIO_NUM       39
#define Y6_GPIO_NUM       36
#define Y5_GPIO_NUM       21
#define Y4_GPIO_NUM       19
#define Y3_GPIO_NUM       18
#define Y2_GPIO_NUM        5
#define VSYNC_GPIO_NUM    25
#define HREF_GPIO_NUM     23
#define PCLK_GPIO_NUM     22
// ─────────────────────────────────────────────────────────────────────────────

httpd_handle_t stream_httpd = NULL;
httpd_handle_t camera_httpd = NULL;

// ── MJPEG STREAM HANDLER ──────────────────────────────────────────────────────
#define PART_BOUNDARY "123456789000000000000987654321"
static const char* STREAM_CONTENT_TYPE =
    "multipart/x-mixed-replace;boundary=" PART_BOUNDARY;
static const char* STREAM_BOUNDARY = "\r\n--" PART_BOUNDARY "\r\n";
static const char* STREAM_PART =
    "Content-Type: image/jpeg\r\nContent-Length: %u\r\n\r\n";

esp_err_t stream_handler(httpd_req_t *req) {
    camera_fb_t *fb = NULL;
    esp_err_t res = ESP_OK;
    char part_buf[64];

    res = httpd_resp_set_type(req, STREAM_CONTENT_TYPE);
    if (res != ESP_OK) return res;

    while (true) {
        fb = esp_camera_fb_get();
        if (!fb) {
            Serial.println("[ERROR] Camera capture failed");
            res = ESP_FAIL;
            break;
        }

        // Send boundary
        res = httpd_resp_send_chunk(req, STREAM_BOUNDARY, strlen(STREAM_BOUNDARY));
        if (res != ESP_OK) { esp_camera_fb_return(fb); break; }

        // Send part header with JPEG content length
        size_t hlen = snprintf(part_buf, sizeof(part_buf), STREAM_PART, fb->len);
        res = httpd_resp_send_chunk(req, part_buf, hlen);
        if (res != ESP_OK) { esp_camera_fb_return(fb); break; }

        // Send JPEG frame
        res = httpd_resp_send_chunk(req, (const char*)fb->buf, fb->len);
        esp_camera_fb_return(fb);
        if (res != ESP_OK) break;
    }

    return res;
}

// ── ALERT HANDLER ─────────────────────────────────────────────────────────────
esp_err_t alert_handler(httpd_req_t *req) {
    Serial.println("[ALERT] Drowsiness detected — buzzer ON");
    digitalWrite(BUZZER_PIN, HIGH);
    delay(2000);
    digitalWrite(BUZZER_PIN, LOW);
    Serial.println("[ALERT] Buzzer OFF");
    httpd_resp_send(req, "OK", 2);
    return ESP_OK;
}

// ── START SERVERS ─────────────────────────────────────────────────────────────
void startServers() {
    // Stream server on port 81
    httpd_config_t stream_config = HTTPD_DEFAULT_CONFIG();
    stream_config.server_port = 81;
    stream_config.ctrl_port   = 32769;

    httpd_uri_t stream_uri = {
        .uri       = "/video",
        .method    = HTTP_GET,
        .handler   = stream_handler,
        .user_ctx  = NULL
    };

    if (httpd_start(&stream_httpd, &stream_config) == ESP_OK) {
        httpd_register_uri_handler(stream_httpd, &stream_uri);
        Serial.println("[INFO] Stream server started on port 81");
    } else {
        Serial.println("[ERROR] Failed to start stream server");
    }

    // Camera/control server on port 80
    httpd_config_t camera_config = HTTPD_DEFAULT_CONFIG();
    camera_config.server_port = 80;

    httpd_uri_t alert_uri = {
        .uri       = "/alert",
        .method    = HTTP_GET,
        .handler   = alert_handler,
        .user_ctx  = NULL
    };

    if (httpd_start(&camera_httpd, &camera_config) == ESP_OK) {
        httpd_register_uri_handler(camera_httpd, &alert_uri);
        Serial.println("[INFO] Control server started on port 80");
    } else {
        Serial.println("[ERROR] Failed to start control server");
    }
}

// ── SETUP ─────────────────────────────────────────────────────────────────────
void setup() {
    Serial.begin(115200);

    pinMode(BUZZER_PIN, OUTPUT);
    digitalWrite(BUZZER_PIN, LOW);

    // Camera init
    camera_config_t config;
    config.ledc_channel = LEDC_CHANNEL_0;
    config.ledc_timer   = LEDC_TIMER_0;
    config.pin_d0       = Y2_GPIO_NUM;
    config.pin_d1       = Y3_GPIO_NUM;
    config.pin_d2       = Y4_GPIO_NUM;
    config.pin_d3       = Y5_GPIO_NUM;
    config.pin_d4       = Y6_GPIO_NUM;
    config.pin_d5       = Y7_GPIO_NUM;
    config.pin_d6       = Y8_GPIO_NUM;
    config.pin_d7       = Y9_GPIO_NUM;
    config.pin_xclk     = XCLK_GPIO_NUM;
    config.pin_pclk     = PCLK_GPIO_NUM;
    config.pin_vsync    = VSYNC_GPIO_NUM;
    config.pin_href     = HREF_GPIO_NUM;
    config.pin_sscb_sda = SIOD_GPIO_NUM;
    config.pin_sscb_scl = SIOC_GPIO_NUM;
    config.pin_pwdn     = PWDN_GPIO_NUM;
    config.pin_reset    = RESET_GPIO_NUM;
    config.xclk_freq_hz = 20000000;
    config.pixel_format = PIXFORMAT_JPEG;

    // Lower resolution = higher FPS over Wi-Fi
    config.frame_size   = FRAMESIZE_QVGA;  // 320x240 — good balance for detection
    config.jpeg_quality = 12;              // 0 (best) to 63 (worst); 10–15 is practical
    config.fb_count     = 2;              // Double buffering

    esp_err_t err = esp_camera_init(&config);
    if (err != ESP_OK) {
        Serial.printf("[ERROR] Camera init failed: 0x%x\n", err);
        return;
    }
    Serial.println("[INFO] Camera initialized");

    // Wi-Fi
    WiFi.begin(ssid, password);
    Serial.print("[INFO] Connecting to Wi-Fi");
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
    }
    Serial.println();
    Serial.print("[INFO] Connected. IP: ");
    Serial.println(WiFi.localIP());

    startServers();

    Serial.println("────────────────────────────────────");
    Serial.print("  Stream : http://");
    Serial.print(WiFi.localIP());
    Serial.println(":81/video");
    Serial.print("  Alert  : http://");
    Serial.print(WiFi.localIP());
    Serial.println(":80/alert");
    Serial.println("────────────────────────────────────");
}

// ── LOOP ──────────────────────────────────────────────────────────────────────
void loop() {
    // HTTP servers are handled by FreeRTOS tasks internally — nothing needed here.
    // Optionally add Wi-Fi reconnect logic:
    if (WiFi.status() != WL_CONNECTED) {
        Serial.println("[WARN] Wi-Fi lost. Reconnecting...");
        WiFi.reconnect();
        delay(5000);
    }
}
